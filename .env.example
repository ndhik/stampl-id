# ─── Database (Neon) ───────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/stample?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/stample?sslmode=require"

# ─── Auth (NextAuth / Auth.js) ────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth → console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) ───────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@stample.id"

# ─── Storage (Cloudflare R2) ──────────────────────────────────────
# cloudflare.com → R2 → Manage API tokens
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="stample-uploads"
R2_PUBLIC_URL="https://your-bucket.r2.dev"

# ─── Cache / Rate Limit (Upstash Redis) ──────────────────────────
# upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Admin Panel ──────────────────────────────────────────────────
ADMIN_EMAIL="admin@stample.id"
# Generate hash: node -e "const b=require('bcryptjs');b.hash('your-password',12).then(console.log)"
ADMIN_PASSWORD_HASH=""
ADMIN_SESSION_SECRET="generate-with: openssl rand -base64 32"

# ─── Invoice / Payment (Manual) ───────────────────────────────────
BANK_NAME="BCA"
BANK_ACCOUNT_NUMBER="1234567890"
BANK_ACCOUNT_NAME="Nama Lengkap Kamu"
WHATSAPP_CONFIRM_NUMBER="08xxxxxxxxxx"

# ─── App URLs ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://stample.id"
NEXT_PUBLIC_TENANT_URL="https://tenant.stample.id"
NEXT_PUBLIC_ADMIN_URL="https://admin.stample.id"

# ─── Local dev override ───────────────────────────────────────────
# Untuk dev lokal, tambahkan di .env.local (jangan di-commit):
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_TENANT_URL="http://localhost:3000"
# NEXT_PUBLIC_ADMIN_URL="http://localhost:3000"
